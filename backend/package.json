{
  "name": "smart-maintenance-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push",
    "prisma:dev": "prisma db push --schema=prisma/schema.dev.prisma && prisma generate --schema=prisma/schema.dev.prisma",
    "prisma:mysql": "prisma db push --schema=prisma/schema.prisma && prisma generate --schema=prisma/schema.prisma",
    "seed": "node prisma/seed.js",
    "setup:dev": "npm run prisma:dev && npm run seed",
    "setup:mysql": "npm run prisma:mysql && npm run seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.2",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
